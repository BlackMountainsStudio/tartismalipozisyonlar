generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- Auth.js (NextAuth) modelleri ---
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum UserRole {
  FREE
  PREMIUM
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  nickname      String?
  password      String?   // bcrypt hash - sadece credentials ile kayıt olanlar için
  role          UserRole  @default(FREE)
  premiumUntil  DateTime? // null = no active premium subscription
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  comments       Comment[]
  commentReports CommentReport[]
  votes          Vote[]

  @@index([email])
  @@index([role])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// --- Admin session management ---
model AdminSession {
  id        String   @id @default(cuid())
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
  revokedAt DateTime?
  ipAddress String?
  userAgent String?

  @@index([token])
  @@index([expiresAt])
}

// --- Uygulama modelleri ---
model Match {
  id           String   @id @default(cuid())
  slug         String?  @unique
  homeTeam     String
  awayTeam     String
  league       String   @default("Süper Lig")
  week         Int
  date         DateTime
  note         String?
  homeScore    Int?
  awayScore    Int?
  refereeId    String?
  varRefereeId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  referee      Referee?  @relation("MatchReferee", fields: [refereeId], references: [id], onDelete: SetNull)
  varReferee   Referee?  @relation("MatchVarReferee", fields: [varRefereeId], references: [id], onDelete: SetNull)

  incidents      Incident[]
  crawledContent CrawledContent[]
  comments       Comment[]
  varEvents      VarEvent[]
  matchVideos    MatchVideo[]

  @@index([homeTeam])
  @@index([awayTeam])
  @@index([week])
  @@index([slug])
  @@index([refereeId])
  @@index([varRefereeId])
  @@index([date])
  @@index([league])
}

model Referee {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  role      String   @default("REFEREE") // REFEREE | VAR
  bio       String?
  photoUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  matchesAsReferee   Match[] @relation("MatchReferee")
  matchesAsVarReferee Match[] @relation("MatchVarReferee")

  @@index([slug])
  @@index([role])
}

model Incident {
  id               String   @id @default(cuid())
  slug             String?
  matchId          String
  minute           Int?
  type             String
  description      String
  confidenceScore  Float
  sources          String   @default("[]")
  status           String   @default("PENDING")
  videoUrl         String?
  relatedVideos    String   @default("[]")
  refereeComments  String   @default("[]")
  newsArticles     String   @default("[]")
  inFavorOf        String?  // Pozisyon lehine olan takım
  against          String?  // Pozisyon aleyhine olan takım
  category         String?  // Roadmap: penalty, red_card, handball, offside, foul, second_yellow
  refereeDecision  String?  // Hakem kararı: PENALTY, CONTINUE, YELLOW_CARD, RED_CARD
  varIntervention  Boolean  @default(false) // VAR müdahale etti mi?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  match            Match             @relation(fields: [matchId], references: [id], onDelete: Cascade)
  comments         Comment[]
  opinions         ExpertOpinion[]
  votes            Vote[]
  varEvents        VarEvent[]
  similarFrom      SimilarPosition[] @relation("SimilarFrom")
  similarTo        SimilarPosition[] @relation("SimilarTo")

  @@index([matchId])
  @@index([status])
  @@index([type])
  @@index([category])
  @@index([slug])
  @@index([inFavorOf])
  @@index([against])
  @@index([varIntervention])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([confidenceScore])
}

// Community Karar Sistemi (Fan Oylaması)
model Vote {
  id           String   @id @default(cuid())
  positionId   String
  userId       String
  decisionType String   // PENALTY, CONTINUE, YELLOW_CARD, RED_CARD
  createdAt    DateTime @default(now())

  incident Incident @relation(fields: [positionId], references: [id], onDelete: Cascade)
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([positionId, userId])
  @@index([positionId])
  @@index([userId])
}

// VAR Müdahale Analizi
model VarEvent {
  id              String   @id @default(cuid())
  matchId         String
  positionId      String
  refereeDecision String?  // İlk hakem kararı
  varCalled       Boolean  @default(false)
  finalDecision   String?  // VAR sonrası nihai karar
  createdAt       DateTime @default(now())

  incident Incident @relation(fields: [positionId], references: [id], onDelete: Cascade)
  match    Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@index([positionId])
}

// Benzer Pozisyon Karşılaştırma
model SimilarPosition {
  positionId        String
  similarPositionId String
  similarityScore   Float

  position        Incident @relation("SimilarFrom", fields: [positionId], references: [id], onDelete: Cascade)
  similarPosition Incident @relation("SimilarTo", fields: [similarPositionId], references: [id], onDelete: Cascade)

  @@id([positionId, similarPositionId])
  @@index([positionId])
  @@index([similarPositionId])
}

model CrawledContent {
  id          String    @id @default(cuid())
  matchId     String
  source      String
  url         String    @unique
  rawContent  String
  processed   Boolean   @default(false)
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@index([source])
  @@index([processed])
}

model Comment {
  id         String   @id @default(cuid())
  matchId    String?
  incidentId String?
  parentId   String?
  userId     String?
  author     String
  content    String
  verdict    String   @default("UNSURE")
  createdAt  DateTime @default(now())

  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  match      Match?    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  incident   Incident? @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  parent     Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies    Comment[] @relation("CommentReplies")
  reports    CommentReport[]

  @@index([matchId])
  @@index([incidentId])
  @@index([parentId])
  @@index([userId])
  @@index([createdAt])
}

model CommentReport {
  id        String   @id @default(cuid())
  commentId String
  userId    String
  reason    String?  @db.Text
  createdAt DateTime @default(now())

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([commentId])
  @@index([userId])
}

model Commentator {
  id          String @id @default(cuid())
  name        String @unique
  slug        String @unique
  role        String
  bio         String
  photoUrl    String?
  birthDate   String?
  birthPlace  String?
  education   String?
  career      String   @default("[]")
  expertise   String   @default("[]")
  socialLinks String   @default("[]")
  createdAt   DateTime @default(now())

  opinions ExpertOpinion[]

  @@index([slug])
}

model ExpertOpinion {
  id            String @id @default(cuid())
  commentatorId String
  incidentId    String
  comment       String
  stance        String @default("NEUTRAL")
  sourceUrl     String?
  createdAt     DateTime @default(now())

  commentator Commentator @relation(fields: [commentatorId], references: [id], onDelete: Cascade)
  incident    Incident    @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@unique([commentatorId, incidentId])
  @@index([commentatorId])
  @@index([incidentId])
  @@index([stance])
}

model Suggestion {
  id        String   @id @default(cuid())
  userId    String?
  name      String
  email     String?
  category  String   @default("GENERAL")
  subject   String
  message   String
  status    String   @default("NEW")
  adminNote String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([status])
  @@index([category])
  @@index([createdAt])
}

// Geçici: Maç videoları ve transcriptleri - doğru maç eşleştirmesini kontrol için
model MatchVideo {
  id          String   @id @default(cuid())
  matchId     String
  videoUrl    String   // YouTube, beIN vb.
  title       String?  // Video başlığı
  durationMin Int?     // Dakika cinsinden süre
  transcript  String?  @db.Text // Altyazı/transcript metni
  source      String?  // youtube, bein, vb.
  notes       String?  @db.Text // Manuel notlar
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId])
}
