generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Match {
  id           String   @id @default(cuid())
  slug         String?  @unique
  homeTeam     String
  awayTeam     String
  league       String   @default("Süper Lig")
  week         Int
  date         DateTime
  note         String?
  refereeId    String?
  varRefereeId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  referee      Referee?  @relation("MatchReferee", fields: [refereeId], references: [id], onDelete: SetNull)
  varReferee   Referee?  @relation("MatchVarReferee", fields: [varRefereeId], references: [id], onDelete: SetNull)

  incidents      Incident[]
  crawledContent CrawledContent[]
  comments       Comment[]

  @@index([homeTeam])
  @@index([awayTeam])
  @@index([week])
  @@index([slug])
  @@index([refereeId])
  @@index([varRefereeId])
}

model Referee {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  role      String   @default("REFEREE") // REFEREE | VAR
  bio       String?
  photoUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  matchesAsReferee   Match[] @relation("MatchReferee")
  matchesAsVarReferee Match[] @relation("MatchVarReferee")

  @@index([slug])
  @@index([role])
}

model Incident {
  id              String  @id @default(cuid())
  slug            String?
  matchId         String
  minute          Int?
  type            String
  description     String
  confidenceScore Float
  sources         String  @default("[]")
  status          String  @default("PENDING")
  videoUrl        String?
  relatedVideos   String  @default("[]")
  refereeComments String  @default("[]")
  newsArticles    String  @default("[]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  match    Match           @relation(fields: [matchId], references: [id], onDelete: Cascade)
  comments Comment[]
  opinions ExpertOpinion[]

  @@index([matchId])
  @@index([status])
  @@index([type])
  @@index([slug])
}

model CrawledContent {
  id          String    @id @default(cuid())
  matchId     String
  source      String
  url         String    @unique
  rawContent  String
  processed   Boolean   @default(false)
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@index([source])
  @@index([processed])
}

model Comment {
  id         String   @id @default(cuid())
  matchId    String?
  incidentId String?
  author     String
  content    String
  createdAt  DateTime @default(now())

  match    Match?    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  incident Incident? @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@index([incidentId])
  @@index([createdAt])
}

model Commentator {
  id          String @id @default(cuid())
  name        String @unique
  slug        String @unique
  role        String
  bio         String
  photoUrl    String?
  birthDate   String?
  birthPlace  String?
  education   String?
  career      String   @default("[]")
  expertise   String   @default("[]")
  socialLinks String   @default("[]")
  createdAt   DateTime @default(now())

  opinions ExpertOpinion[]

  @@index([slug])
}

model ExpertOpinion {
  id            String @id @default(cuid())
  commentatorId String
  incidentId    String
  comment       String
  stance        String @default("NEUTRAL")
  sourceUrl     String?
  createdAt     DateTime @default(now())

  commentator Commentator @relation(fields: [commentatorId], references: [id], onDelete: Cascade)
  incident    Incident    @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@unique([commentatorId, incidentId])
  @@index([commentatorId])
  @@index([incidentId])
  @@index([stance])
}

model Suggestion {
  id        String   @id @default(cuid())
  name      String
  email     String?
  category  String   @default("GENERAL")
  subject   String
  message   String
  status    String   @default("NEW")
  adminNote String?
  createdAt DateTime @default(now())

  @@index([status])
  @@index([category])
  @@index([createdAt])
}
