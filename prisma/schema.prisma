generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Match {
  id        String   @id @default(cuid())
  homeTeam  String
  awayTeam  String
  league    String   @default("Süper Lig")
  week      Int
  date      DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  incidents      Incident[]
  crawledContent CrawledContent[]
  comments       Comment[]

  @@index([homeTeam])
  @@index([awayTeam])
  @@index([week])
}

model Incident {
  id              String  @id @default(cuid())
  matchId         String
  minute          Int?
  type            String
  description     String
  confidenceScore Float
  sources         String  @default("[]")
  status          String  @default("PENDING")
  videoUrl        String?
  refereeComments String  @default("[]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  match    Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  comments Comment[]

  @@index([matchId])
  @@index([status])
  @@index([type])
}

model CrawledContent {
  id          String    @id @default(cuid())
  matchId     String
  source      String
  url         String    @unique
  rawContent  String
  processed   Boolean   @default(false)
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@index([source])
  @@index([processed])
}

model Comment {
  id         String   @id @default(cuid())
  matchId    String?
  incidentId String?
  author     String
  content    String
  createdAt  DateTime @default(now())

  match    Match?    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  incident Incident? @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@index([incidentId])
  @@index([createdAt])
}

model Suggestion {
  id        String   @id @default(cuid())
  name      String
  email     String?
  category  String   @default("GENERAL")
  subject   String
  message   String
  status    String   @default("NEW")
  adminNote String?
  createdAt DateTime @default(now())

  @@index([status])
  @@index([category])
  @@index([createdAt])
}
